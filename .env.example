# Backend
DATABASE_URL=postgresql+asyncpg://fetch:fetch@db:5432/fetch
# JWT_SECRET must be unique and at least 32 characters — generate with
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-a-32plus-char-random-string-generated-locally
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/app/uploads
CORS_ORIGINS=http://localhost:3174
RATE_LIMIT_ENABLED=true

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Observability (leave empty to disable)
SENTRY_DSN=
LOG_LEVEL=INFO
LOG_FORMAT=json

# Moderation (leave empty for stub/approve-all mode)
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# Frontend
VITE_API_BASE_URL=http://localhost:9001/api/v1
